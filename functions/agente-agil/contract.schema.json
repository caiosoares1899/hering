{
  "$ref": "#/definitions/AgentResponseEnvelope",
  "definitions": {
    "AgentResponseEnvelope": {
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "cardId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "outputs": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "comentario"
                  },
                  "texto": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "texto"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "link"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "titulo": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "url",
                  "titulo"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "relatorio_html"
                  },
                  "html": {
                    "type": "string",
                    "minLength": 1
                  },
                  "titulo": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "html",
                  "titulo"
                ],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "dryRun": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "requestId",
        "cardId",
        "status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
